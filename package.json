{
  "name": "loyalflow",
  "version": "0.1.0",
  "description": "LoyalFlow — multi-tenant digital loyalty card SaaS platform",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "typecheck": "vue-tsc -b --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@heroicons/vue": "^2.1.5",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/vue-query": "^5.59.0",
    "@vueuse/core": "^11.1.0",
    "@vueuse/motion": "^3.0.3",
    "chart.js": "^4.4.4",
    "pinia": "^2.2.4",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "vue": "^3.5.11",
    "vue-chartjs": "^5.3.1",
    "vue-i18n": "^9.14.1",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.7.4",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.11.1",
    "eslint-plugin-vue": "^9.28.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vue-tsc": "^2.1.6"
  }
}
